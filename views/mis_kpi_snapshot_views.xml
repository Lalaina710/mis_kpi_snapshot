<odoo>

    <!-- List view -->
    <record id="view_mis_kpi_snapshot_list" model="ir.ui.view">
        <field name="name">mis.kpi.snapshot.list</field>
        <field name="model">mis.kpi.snapshot</field>
        <field name="arch" type="xml">
            <list string="MIS KPI Snapshots"
                  default_order="computed_at desc, instance_id, kpi_sequence">
                <field name="computed_at"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="report_name"/>
                <field name="instance_name"/>
                <field name="period_name"/>
                <field name="kpi_sequence" optional="hide"/>
                <field name="kpi_name" optional="hide"/>
                <field name="kpi_description"/>
                <field name="value" sum="Total" digits="[20,2]"/>
                <field name="value_str" optional="hide"/>
                <field name="is_subtotal" widget="boolean_toggle" optional="show"/>
                <field name="period_date_from" optional="hide"/>
                <field name="period_date_to" optional="hide"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form view (read-only) -->
    <record id="view_mis_kpi_snapshot_form" model="ir.ui.view">
        <field name="name">mis.kpi.snapshot.form</field>
        <field name="model">mis.kpi.snapshot</field>
        <field name="arch" type="xml">
            <form string="MIS KPI Snapshot" create="false" edit="false">
                <header/>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Reference">
                            <field name="instance_id"/>
                            <field name="report_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Snapshot Meta">
                            <field name="computed_at"/>
                            <field name="computed_by"/>
                        </group>
                    </group>
                    <group>
                        <group string="KPI">
                            <field name="kpi_name"/>
                            <field name="kpi_description"/>
                            <field name="kpi_sequence"/>
                            <field name="is_subtotal"/>
                        </group>
                        <group string="Period">
                            <field name="period_id"/>
                            <field name="period_name"/>
                            <field name="period_date_from"/>
                            <field name="period_date_to"/>
                        </group>
                    </group>
                    <group string="Value">
                        <field name="value" digits="[20,2]"/>
                        <field name="value_str"/>
                    </group>
                    <footer>
                        <button name="action_open_instance"
                                type="object"
                                string="Open Source Instance"
                                class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_mis_kpi_snapshot_search" model="ir.ui.view">
        <field name="name">mis.kpi.snapshot.search</field>
        <field name="model">mis.kpi.snapshot</field>
        <field name="arch" type="xml">
            <search string="Search Snapshots">
                <field name="instance_id"/>
                <field name="report_id"/>
                <field name="kpi_name"/>
                <field name="kpi_description"/>
                <field name="period_name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter name="subtotals_only"
                        string="Subtotals Only"
                        domain="[('is_subtotal', '=', True)]"/>
                <filter name="today"
                        string="Snapshotted Today"
                        domain="[('computed_at', '&gt;=', (context_today()).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="last_7_days"
                        string="Last 7 Days"
                        domain="[('computed_at', '&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_report"
                            string="Report Template"
                            context="{'group_by': 'report_id'}"/>
                    <filter name="group_instance"
                            string="Instance"
                            context="{'group_by': 'instance_id'}"/>
                    <filter name="group_period"
                            string="Period"
                            context="{'group_by': 'period_name'}"/>
                    <filter name="group_kpi"
                            string="KPI"
                            context="{'group_by': 'kpi_name'}"/>
                    <filter name="group_company"
                            string="Company"
                            context="{'group_by': 'company_id'}"
                            groups="base.group_multi_company"/>
                    <filter name="group_day"
                            string="Snapshot Day"
                            context="{'group_by': 'computed_at:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window action -->
    <record id="action_mis_kpi_snapshot" model="ir.actions.act_window">
        <field name="name">MIS KPI Snapshots</field>
        <field name="res_model">mis.kpi.snapshot</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mis_kpi_snapshot_search"/>
        <field name="context">{'search_default_last_7_days': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No KPI snapshots yet.
            </p>
            <p>
                Configure at least one <b>MIS Report Instance</b> with periods,
                then click <b>Snapshot Now</b> on the instance form or run the
                <b>MIS KPI Snapshot</b> daily cron.
            </p>
        </field>
    </record>

</odoo>
