<odoo>
    <data noupdate="1">

        <!-- Server action for the cron -->
        <record id="action_mis_kpi_snapshot_daily" model="ir.actions.server">
            <field name="name">MIS KPI Snapshot — Daily compute all instances</field>
            <field name="model_id" ref="model_mis_kpi_snapshot"/>
            <field name="state">code</field>
            <field name="code">model.snapshot_all_active_instances()</field>
        </record>

        <!-- Cron linked to the server action -->
        <record id="cron_mis_kpi_snapshot_daily" model="ir.cron">
            <field name="cron_name">MIS KPI Snapshot — Daily compute all instances</field>
            <field name="ir_actions_server_id" ref="action_mis_kpi_snapshot_daily"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="nextcall"
                eval="(datetime.now() + timedelta(days=1)).replace(hour=3, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

    </data>
</odoo>
